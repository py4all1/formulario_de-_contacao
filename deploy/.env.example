# =============================================================================
# Variaveis de ambiente de PRODUCAO - app Electrolux
# =============================================================================
# Na VPS este arquivo vira /etc/electrolux.env (fora do projeto, fora do Git).
# Gere uma SECRET_KEY nova com:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
# IMPORTANTE: a SECRET_KEY costuma ter caracteres como ( ) & $ - sempre coloque
# o valor entre ASPAS SIMPLES. O systemd remove as aspas automaticamente.
# =============================================================================

DJANGO_SECRET_KEY='COLE_AQUI_UMA_CHAVE_NOVA_E_SECRETA'
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=electrolux.taxcode.com.br
DJANGO_CSRF_TRUSTED_ORIGINS=https://electrolux.taxcode.com.br
